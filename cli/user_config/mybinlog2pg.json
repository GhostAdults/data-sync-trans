{
  "id": "binlog_sync",
  "source": {
    "name": "binlog_source",
    "type": "mysql_binlog",
    "config": {
      "connection": {
        "host": "127.0.0.1",
        "port": 3306,
        "database": "my_db",
        "username": "root",
        "password": "123456",
        "server_id": 1,
        "table": "user_x",
        "table_filter": "my_db.user_x"
      }
    }
  },
  "target": {
    "name": "db_target",
    "type": "database",
    "writer_mode": "insert",
    "config": {
      "connection": {
        "type": "postgres",
        "host": "127.0.0.1",
        "port": 5432,
        "database": "postgres",
        "username": "postgres",
        "password": "123456",
        "table": "user_w",
        "key_columns": [
          "id"
        ],
        "max_connections": 20,
        "acquire_timeout_secs": 30,
        "use_transaction": true
      }
    }
  },
  "column_mapping": {
    "id": "id",
    "userAccount": "expr: 'IMPORTED'",
    "userPassword": "userPassword"
  },
  "column_types": {
    "id": "int",
    "userAccount": "string",
    "userPassword": "string"
  },
  "sync_mode": "cdc",
  "batch_size": 1,
  "channel_buffer_size": 12000
}
